# Fastify
HOST=0.0.0.0
PORT=4000

# Prisma/PostgreSQL.
# Leave unset in apps/api/.env to use the API's in-memory local development store.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/plyco

# Airtable provider catalog.
AIRTABLE_BASE=appXXXXXXXXXXXXXX
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# Private Google Cloud Storage bucket for generated PDF documents.
DOCUMENT_PDF_BUCKET=plyco-prod

# Google OAuth authentication.
API_PUBLIC_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173
GOOGLE_OAUTH_CLIENT_ID=google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=google-client-secret
SESSION_KEY=replace-with-at-least-32-random-characters
